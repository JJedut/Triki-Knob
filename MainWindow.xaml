<Window x:Class="Triki_Knob.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Triki_Knob"
        mc:Ignorable="d"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        Title="Triki-Knob" Height="600" Width="900">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Assets/Icons.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            
            <Style x:Key="TitleBarButtonStyle" TargetType="Button">
                <Setter Property="Width" Value="46"/>
                <Setter Property="Height" Value="32"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="#242423"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#9caea9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#e8eddf"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
                </Setter>
                </Style>
            <Style x:Key="CloseButtonStyle" TargetType="Button"
                   BasedOn="{StaticResource TitleBarButtonStyle}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg" CornerRadius="0,12,0,0" Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="#ef6461"/>
                            <Setter Property="Foreground" Value="#ccc5b9"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="#ff5e5b"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Background" Value="#242423"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg"
                                        Property="Background"
                                        Value="#3D3D3A"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg"
                                        Property="Background"
                                        Value="#111111"/>
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bg"
                                        Property="Opacity"
                                        Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SegmentToggleStyle" TargetType="RadioButton">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Foreground" Value="#242423"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bg"
                                Background="Transparent"
                                CornerRadius="7"
                                Padding="12,0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#242423"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#E8EDDF"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bg" Property="Background" Value="#242423"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        </ResourceDictionary>
    </Window.Resources>
    
    <Border CornerRadius="12" Background="#F1F3EB" BorderBrush="#A5ADA8" BorderThickness="1">
        <Grid>
            <Grid Height="32" VerticalAlignment="Top" Background="Transparent"
                  MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
            
                <StackPanel 
                    Orientation="Horizontal" 
                    VerticalAlignment="Center"
                    Margin="12,0">
                    <TextBlock 
                        Text="Triki-Knob"
                        FontSize="16"
                        FontWeight="Bold"
                        Foreground="#242423"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Style="{StaticResource TitleBarButtonStyle}"
                            Click="Minimize_Click">
                        <TextBlock Text="&#x2014;" FontSize="12" Foreground="#242423"/>
                    </Button>
                    <Button Style="{StaticResource CloseButtonStyle}"
                            Click="Close_Click">
                        <TextBlock Text="&#x2715;" FontSize="12"/>
                    </Button>
                </StackPanel>
            </Grid>
        
            <Grid Margin="0,32,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <Border Grid.Column="0" Background="#FFFFFF"
                        CornerRadius="12"
                        BorderThickness="1"
                        BorderBrush="#E5E5E0"
                        Margin="8"
                        Padding="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/> 
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" 
                                   Text="CONNECTION" 
                                   FontWeight="SemiBold" 
                                   Foreground="#555555" 
                                   FontSize="12"
                                   Margin="0,0,0,20"/>
                        
                        <Grid Grid.Row="1" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0" 
                                        Orientation="Horizontal" 
                                        VerticalAlignment="Center">
                                <Ellipse x:Name="StatusIndicator"
                                         Width="8" 
                                         Height="8" 
                                         Fill="#EF6461" 
                                         Margin="0,0,8,0"/>
                                
                                <TextBlock x:Name="TxtStatus" 
                                           Text="Rozłączony" 
                                           FontWeight="SemiBold" 
                                           FontSize="16" 
                                           Foreground="#242423"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" 
                                        Orientation="Horizontal" 
                                        VerticalAlignment="Center" 
                                        Margin="12,0,0,0">
                                <ContentControl Content="{StaticResource BatteryIcon}"
                                                Margin="0,0,6,0"/>

                                <TextBlock x:Name="TxtBattery"
                                           Text="--"
                                           FontSize="12"
                                           Foreground="#555555"/>
                            </StackPanel>
                        </Grid>
                        
                        <Button Grid.Row="2" 
                                Click="BlConnect_Click"
                                Content="Connect"
                                x:Name="BtnConnect"
                                Style="{StaticResource PrimaryButtonStyle}"/>
                    </Grid>
                </Border>
                
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> 
                        <RowDefinition Height="*"/>    
                    </Grid.RowDefinitions>
                    
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <Border Grid.Column="0" Background="#FFFFFF"
                                CornerRadius="12"
                                BorderThickness="1"
                                BorderBrush="#E5E5E0"
                                Margin="8"
                                Padding="16">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/> 
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Text="VOLUME MAPPING"
                                               FontWeight="SemiBold"
                                               Foreground="#555555"
                                               FontSize="12"
                                               VerticalAlignment="Center"/>

                                    <ContentControl Grid.Column="1"
                                                    Content="{StaticResource VolumeIcon}"
                                                    VerticalAlignment="Center"/>
                                </Grid>

                                <Border Grid.Row="1"
                                        Background="#F7F8F2"
                                        BorderBrush="#D9DDD2"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="3"
                                        Margin="0,0,0,14">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <RadioButton x:Name="VolumeLeftDirection"
                                                     Grid.Column="0"
                                                     GroupName="VolumeDirection"
                                                     Content="Left"
                                                     Style="{StaticResource SegmentToggleStyle}"
                                                     Checked="VolumeDirection_Checked"/>

                                        <RadioButton x:Name="VolumeRightDirection"
                                                     Grid.Column="1"
                                                     GroupName="VolumeDirection"
                                                     Content="Right"
                                                     IsChecked="True"
                                                     Style="{StaticResource SegmentToggleStyle}"
                                                     Checked="VolumeDirection_Checked"/>
                                    </Grid>
                                </Border>

                                <Grid Grid.Row="2">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Grid.Column="0"
                                               Text="Sensitivity"
                                               FontSize="16"
                                               Foreground="#242423"
                                               VerticalAlignment="Center"/>

                                    <TextBlock x:Name="TxtVolumeSensitivity"
                                               Grid.Row="0"
                                               Grid.Column="1"
                                               Text="75%"
                                               FontSize="16"
                                               Foreground="#242423"
                                               VerticalAlignment="Center"/>

                                    <Slider x:Name="VolumeSensitivitySlider"
                                            Grid.Row="1"
                                            Grid.ColumnSpan="2"
                                            Minimum="10"
                                            Maximum="100"
                                            Value="75"
                                            TickFrequency="5"
                                            IsSnapToTickEnabled="True"
                                            Margin="0,10,0,0"
                                            ValueChanged="VolumeSensitivitySlider_ValueChanged"/>
                                </Grid>
                            </Grid>
                        </Border>
                        
                        <Border Grid.Column="1" Background="#FFFFFF"
                                CornerRadius="12"
                                BorderThickness="1"
                                BorderBrush="#E5E5E0"
                                Margin="8"
                                Padding="16">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/> 
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Text="SCROLL MAPPING"
                                               FontWeight="SemiBold"
                                               Foreground="#555555"
                                               FontSize="12"
                                               VerticalAlignment="Center"/>

                                    <ContentControl Grid.Column="1"
                                                    Content="{StaticResource ArrowDownUpIcon}"
                                                    VerticalAlignment="Center"/>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                    
                    <Border Grid.Row="1" Background="#FFFFFF"
                            CornerRadius="12"
                            BorderThickness="1"
                            BorderBrush="#E5E5E0"
                            Margin="8"
                            Padding="16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/> 
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" 
                                       Text="ACTIVITY LOG" 
                                       FontWeight="SemiBold" 
                                       Foreground="#555555" 
                                       FontSize="12"
                                       Margin="0,0,0,20"/>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
